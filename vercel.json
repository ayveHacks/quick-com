{
  "buildCommand": "cd frontend && npm run build",
  "installCommand": "npm install --prefix frontend && pip install --prefix backend -r backend/requirements.txt",
  "experimentalServices": {
    "frontend": {
      "framework": "nextjs",
      "routePrefix": "/"
    },
    "backend": {
      "entrypoint": "backend/app/main.py",
      "runtime": "python",
      "routePrefix": "/_/backend"
    }
  }
}
